{
  "version": 2,
  "framework": "nextjs",
  "regions": ["iad1"],
  "github": {
    "silent": false
  },
  "build": {
    "env": {
      "TURBOPACK": "0"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
