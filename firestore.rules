rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ----------------------------------------------------------------------
    // Functions
    // ----------------------------------------------------------------------
    
    // Check if the user has admin claim or is the admin email
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.email == "youssefosama@gmail.com" ||
        request.auth.token.email == "youssef@yaqeen.app" ||
        request.auth.token.email.matches(".*youssef.*")
      );
    }
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ----------------------------------------------------------------------
    // Rules
    // ----------------------------------------------------------------------

    // Users and their subcollections
    match /users/{userId} {
      allow read: if true; // Allows leaderboard to read totalPoints
      allow create: if request.auth.uid == userId;
      allow update, delete: if request.auth.uid == userId || isAdmin();
      
      // Subcollections inside users (like completed_quests, completed_surahs)
      match /{subCollection}/{document=**} {
        allow read: if true;
        allow write: if request.auth.uid == userId || isAdmin();
      }
    }

    // Global Quests
    match /global_quests/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chatbot Logs
    match /chatbot_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if true; // Any user can add logs via the chatbot
    }
    
    // Admin Push Notifications
    match /admin_push_notifications/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TikTok Accounts
    match /tiktok_accounts/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // TikTok Scheduled/Published Jobs
    match /tiktok_jobs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // TikTok Logs
    match /tiktok_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }



    // Email Logs
    match /emailLogs/{document=**} {
      allow read: if isAdmin(); // Stronger: only admin should read logs
      allow write: if true;     // AuthGate writes here without auth
    }

    // Admin Logs
    match /admin_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Support Tickets
    match /support_tickets/{document=**} {
      allow read: if isAdmin();
      allow write: if isAuthenticated(); // Only logged-in users can send tickets
    }

    // Subscription Requests
    match /subscription_requests/{document=**} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Showcase
    match /showcase/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
      allow update, delete: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // Community Posts (Social Feed)
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin();
      
      match /likes/{likeId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if true; // Allow anonymous comments
        allow update, delete: if (isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.commenterId)) || isAdmin();
      }

      match /reports/{reportId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Friend Requests
    match /friend_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId
                    && (
                      !('blockedUsers' in get(/databases/$(database)/documents/users/$(request.resource.data.receiverId)).data)
                      || !(request.auth.uid in get(/databases/$(database)/documents/users/$(request.resource.data.receiverId)).data.blockedUsers)
                    );
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    // Friendships
    match /friendships/{friendshipId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.users;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.users;
    }

    // Direct Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // Duels (Friend Challenges)
    match /duels/{duelId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated();
    }

    // Admin configuration (maintenance status, etc.)
    match /admin/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Backgrounds
    match /backgrounds/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Video Renders Logs
    match /video_renders/{jobId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Default Fallback
    match /{allPaths=**} {
      // DENY ALL BY DEFAULT FOR UNMATCHED PATHS
      allow read, write: if false;
    }
  }
}
